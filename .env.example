# ─── AWS ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ─── Nova Sonic ──────────────────────────────────────────────────────────────
# Model ID for AWS Bedrock Nova Sonic
NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v1:0

# ─── Bedrock Knowledge Base (SEC RAG) ───────────────────────────────────────
# Optional: leave empty to use local FAISS fallback path
BEDROCK_KB_ID=
BEDROCK_KB_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.titan-embed-text-v2:0

# ─── Market Data Providers ───────────────────────────────────────────────────
# Finnhub is primary for live/daily bars and volatility
FINNHUB_API_KEY=your_finnhub_api_key_here

# Polygon is fallback provider for EOD aggregate snapshot
POLYGON_API_KEY=your_polygon_api_key_here

# ─── Vault (Obsidian / local markdown) ──────────────────────────────────────
# Absolute path to your Obsidian vault, or leave as default for local ./vault/
VAULT_PATH=./vault

# ─── Ironclad Runtime (Wasm sandbox — optional) ─────────────────────────────
# Path to the compiled ironclad-runtime binary.
# If not present, Monte Carlo runs natively in Python.
IRONCLAD_RUNTIME_PATH=./ironclad/ironclad-runtime

# ─── App ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO