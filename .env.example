# ── AWS Credentials ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Nova Sonic ──────────────────────────────────────────────────────────────
NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0

# ── Bedrock Knowledge Base (for SEC RAG) ───────────────────────────────────
BEDROCK_KB_ID=
BEDROCK_KB_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.titan-embed-text-v2:0

# ── Market Data APIs ───────────────────────────────────────────────────────
POLYGON_API_KEY=
FINNHUB_API_KEY=
TIINGO_API_KEY=

# ── Note Generation (Vault Logger) ─────────────────────────────────────────
NOTE_LLM_PROVIDER=groq          # groq | nova_lite | none
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
NOTE_LLM_TIMEOUT_SECONDS=20

# ── Vault ──────────────────────────────────────────────────────────────────
# Path where research notes (Markdown) will be saved.
# Example (Windows): G:/My Drive/Obsidian/Junkyard/
# Example (macOS/Linux): /Users/you/Obsidian/Junkyard/
VAULT_PATH=G:/My Drive/Obsidian/Junkyard/

# ── Ironclad Wasm Sandbox (for Monte Carlo) ────────────────────────────────
# Path to ironclad-runtime binary. If not present, Monte Carlo falls back
# to native Python execution.
IRONCLAD_RUNTIME_PATH=./ironclad/ironclad-runtime

# ── App ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
